{
  "db_name": "SQLite",
  "query": "\n            SELECT\n                psk.id,\n                p.slug AS project_slug,\n                psk.name,\n                psk.public_key,\n                psk.encrypted_private_key,\n                psk.nonce,\n                psk.created_at,\n                psk.retired_at\n            FROM project_signing_keys psk\n            JOIN projects p ON p.id = psk.project_id\n            WHERE p.slug = ?\n              AND psk.retired_at IS NULL\n            LIMIT 1\n            ",
