  "query": "\n                SELECT\n                    pins.scope_key,\n                    pins.name,\n                    projects.slug AS project_slug,\n                    pins.store_path_hash,\n                    pins.store_path,\n                    pins.created_at,\n                    pins.updated_at\n                FROM pins\n                LEFT JOIN projects ON projects.id = pins.project_id\n                ORDER BY pins.scope_key ASC, pins.name ASC\n                ",
